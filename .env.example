# ─── General ────────────────────────────────────────────────────────────────
# Public domain served by Caddy (e.g. archive.example.com). Use localhost for dev.
DOMAIN=
# Timezone for containers and schedulers.
TZ=Europe/Amsterdam

# ─── Postgres (shared by Forgejo + orchestrator) ─────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=
# Forgejo database
FORGEJO_DB_NAME=forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=
# Orchestrator database
ORCHESTRATOR_DB_NAME=orchestrator
ORCHESTRATOR_DB_USER=orchestrator
ORCHESTRATOR_DB_PASSWORD=

# ─── Forgejo ─────────────────────────────────────────────────────────────────
# Root URL Forgejo advertises for clone/redirect links.
FORGEJO_ROOT_URL=https://localhost/
# Internal URL the orchestrator uses to reach the Forgejo API (compose network).
FORGEJO_API_URL=http://forgejo:3000
# Admin API token, created in the Forgejo UI after first-boot install. Full-scope.
FORGEJO_ADMIN_TOKEN=

# ─── Django orchestrator ─────────────────────────────────────────────────────
DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
# Comma-separated hostnames Django will serve.
DJANGO_ALLOWED_HOSTS=localhost
# Fernet key used to encrypt PATs / push tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
# Superuser bootstrapped on first migrate (dev convenience).
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# ─── Sync behaviour ──────────────────────────────────────────────────────────
# How often (hours) to re-run GitHub discovery for new repos.
DISCOVERY_INTERVAL_HOURS=6
# Skip repos larger than this (MB). 0 = no cap.
MAX_REPO_SIZE_MB=2048
# Pause creating new mirrors when the Forgejo volume passes this usage percent.
DISK_PAUSE_THRESHOLD_PERCENT=90
